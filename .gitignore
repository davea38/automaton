# Automaton persistent state (git-tracked — DO NOT add to gitignore)
# .automaton/budget-history.json
# .automaton/learnings.json
# .automaton/run-summaries/
# .automaton/test_results.json
# .automaton/self_modifications.json
# .automaton/garden/              # Idea garden — individual idea JSON files
# .automaton/garden/_index.json   # Garden index (regenerated but tracked for bootstrap)
# .automaton/signals.json         # Stigmergic signals (accumulated across runs)
# .automaton/votes/               # Quorum vote records (audit trail, spec-39)
# .automaton/evolution-metrics.json  # Growth metrics snapshots and baselines (spec-43)
